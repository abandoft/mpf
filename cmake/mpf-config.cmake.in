@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/mpf-targets.cmake")

set(mpf_core_FOUND TRUE)
set(mpf_javascript_FOUND @MPF_ENABLE_JAVASCRIPT_BACKEND@)
set(mpf_cpp_FOUND @MPF_ENABLE_CPP_BACKEND@)
set(MPF_JAVASCRIPT_BACKEND_AVAILABLE @MPF_ENABLE_JAVASCRIPT_BACKEND@)
set(MPF_CPP_BACKEND_AVAILABLE @MPF_ENABLE_CPP_BACKEND@)

check_required_components(mpf)
