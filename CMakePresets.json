{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "MPF_BUILD_CLI": "ON",
        "MPF_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "dev",
      "inherits": "base",
      "displayName": "Developer build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MPF_ENABLE_WERROR": "ON"
      }
    },
    {
      "name": "release",
      "inherits": "base",
      "displayName": "Release build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "sanitizers",
      "inherits": "dev",
      "displayName": "ASan and UBSan build",
      "cacheVariables": {
        "MPF_ENABLE_SANITIZERS": "ON"
      },
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "quality",
      "inherits": "dev",
      "displayName": "Clang static analysis",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "MPF_ENABLE_CLANG_TIDY": "ON"
      },
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "coverage",
      "inherits": "dev",
      "displayName": "Clang source-based coverage",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "MPF_ENABLE_COVERAGE": "ON",
        "MPF_REQUIRE_DIFFERENTIAL_RUNTIME": "ON"
      },
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "buildPresets": [
    { "name": "dev", "configurePreset": "dev" },
    { "name": "release", "configurePreset": "release" },
    { "name": "sanitizers", "configurePreset": "sanitizers" },
    { "name": "quality", "configurePreset": "quality" },
    { "name": "coverage", "configurePreset": "coverage", "targets": ["mpf-coverage"] }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "sanitizers",
      "configurePreset": "sanitizers",
      "output": { "outputOnFailure": true }
    }
  ]
}
